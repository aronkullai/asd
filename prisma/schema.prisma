generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Casino {
  id                    String           @id @default(cuid())
  name                  String
  slug                  String           @unique
  affiliateLink         String
  trustpilotProfileUrl  String
  promoFetchSourceType  String           @default("manual")
  promoFetchSourceUrl   String
  licenseInfo           String           @default("")
  areaRegulations       String           @default("")
  regulator             String           @default("")
  payoutSummary         String           @default("")
  supportQuality        String           @default("")
  supportChannels       String           @default("")
  safetyFeatures        String           @default("")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  promoCodes            PromoCode[]
  reviews               Review[]
  userRatings           UserRating[]
  trustpilotMeta        TrustpilotMeta?
  promoCodeChanges      PromoCodeChange[]
}

model PromoCode {
  id             String            @id
  casinoId       String?
  casinoSlug     String
  casino         Casino            @relation(fields: [casinoSlug], references: [slug], onDelete: Cascade)
  code           String
  label          String
  benefit        String
  benefitTitle   String            @default("")
  benefitDescription String?
  bonusType      String?
  minDeposit     Int?
  wageringRequirements String?
  description    String?
  conditions     String?
  source         String            @default("external")
  sourceId       String            @default("External")
  sourceSiteId   String?
  isAffiliateOwned Boolean         @default(false)
  priority       Int               @default(0)
  estimatedValue Int?
  requirements   String
  validFrom      DateTime?
  validUntil     DateTime?
  maxUses         Int?
  usesSoFar       Int               @default(0)
  region          String?
  isVerified      Boolean           @default(false)
  isActive       Boolean           @default(true)
  discoveredAt   DateTime          @default(now())
  lastCheckedAt  DateTime
  lastUpdatedAt  DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  changes        PromoCodeChange[]
  history        PromoCodeHistory[]
  checkLogs      PromoCodeCheckLog[]

  @@unique([casinoSlug, code, sourceId])
  @@index([casinoSlug, isVerified, isActive])
}

model Review {
  id            String   @id @default(cuid())
  casinoSlug    String
  casino        Casino   @relation(fields: [casinoSlug], references: [slug], onDelete: Cascade)
  reviewerName  String
  source        String   @default("PromoGuard user")
  authorName    String?
  rating        Int
  title         String?
  body          String?
  text          String
  reviewedAt    DateTime
  externalUrl   String?
  isHighlighted Boolean  @default(false)
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([casinoSlug, source])
  @@index([casinoSlug, isHighlighted])
}

model TrustpilotMeta {
  id             String   @id @default(cuid())
  casinoSlug     String   @unique
  casino         Casino   @relation(fields: [casinoSlug], references: [slug], onDelete: Cascade)
  businessUnitId String?
  score          String
  stars          String?
  reviewCount    String
  profileUrl     String
  latestReviews  Json?
  lastFetchedAt  DateTime?
  lastUpdatedAt  DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PromoCodeChange {
  id           String    @id @default(cuid())
  casinoSlug   String
  casino       Casino    @relation(fields: [casinoSlug], references: [slug], onDelete: Cascade)
  promoCodeId  String?
  promoCode    PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  oldCode      String?
  newCode      String
  changeType   String
  createdAt    DateTime  @default(now())
}

model PromoCodeHistory {
  id            String    @id @default(cuid())
  promoCodeId   String?
  promoCode     PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  casinoSlug    String
  code          String
  sourceId      String
  action        String
  before        Json?
  after         Json?
  message       String?
  createdAt     DateTime  @default(now())
}

model PromoCodeCheckLog {
  id           String    @id @default(cuid())
  promoCodeId  String?
  promoCode    PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  casinoSlug   String
  code         String
  sourceId     String
  status       String
  message      String?
  checkedAt    DateTime  @default(now())

  @@index([promoCodeId, checkedAt])
  @@index([casinoSlug, checkedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  ratings      UserRating[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model UserRating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  casinoId  String
  casino    Casino   @relation(fields: [casinoId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, casinoId])
  @@index([casinoId, createdAt])
}
