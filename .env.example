# PostgreSQL connection string used by Prisma.
# Use a pooled production URL from Neon, Supabase, Prisma Postgres, Vercel Postgres, or another hosted Postgres provider.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Optional: promo finder schedule and behavior.
PROMO_RESEARCHER_INTERVAL_MINUTES=30
PROMO_RESEARCHER_MAX_RETRIES=2
PROMO_RESEARCHER_DELAY_MS=500

# Optional: approved public pages for promo-code scans.
# Comma-separate multiple URLs. Use the casino slug in uppercase with hyphens changed to underscores.
# Example:
# PROMO_SOURCE_URLS_STAKE="https://example.com/stake-codes,https://example.com/stake-bonuses"
